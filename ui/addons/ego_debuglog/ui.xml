<?xml version="1.0" encoding="UTF-8"?>
<addon name="ego_debuglog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../core/coreaddon.xsd">
  <environment type="menus">
    <file name="debuglog.lua" />
    <dependency name="ego_viewHelper" />
    <savedvariable name="__CORE_DEBUGLOG_LOG" storage="userdata" />
    <bindinggroup id="debuglog" context="INPUT_CONTEXT_ADDON_DEBUGLOG" alwaysactive="true">
      <binding action="INPUT_ACTION_OPEN_DEBUG_LOG" />
      <!-- Hotkey API - working pool: DEBUG_0-9, DEBUG_A-Z, DEBUG_F1-F12
           (48 actions, numeric ids 23-70). See claude/mod-hotkey_api.md. -->
      <binding action="INPUT_ACTION_DEBUG_0" />
      <binding action="INPUT_ACTION_DEBUG_1" />
      <binding action="INPUT_ACTION_DEBUG_2" />
      <binding action="INPUT_ACTION_DEBUG_3" />
